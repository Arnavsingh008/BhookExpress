# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# For Local Development (no auth):
# MONGODB_URI=mongodb://localhost:27017/food-del

# For Docker Development (no auth):
MONGODB_URI=mongodb://mongodb:27017/food-del

# For MongoDB Atlas (Cloud with auth):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/food-del

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# IMPORTANT: 
# - For Local/Docker: Use any string (e.g., "mysecretkey")
# - For Production: Generate a strong random key (minimum 32 characters)
#   Use: https://randomkeygen.com/ or generate with: openssl rand -hex 32
# Never use weak secrets in production!
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ==========================================
# RAZORPAY PAYMENT GATEWAY
# ==========================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=4000

# ==========================================
# FRONTEND URL
# ==========================================
FRONTEND_URL=http://localhost:5173
